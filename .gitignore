# ══════════════════════════════════════════════════════════════
# Potato Disease Classification — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# ── Virtual Environments ──
myenv/
.venv/
venv/
env/

# ── Environment / Secrets ──
.env
check.py

# ── ML Models (too large for Git — use Git LFS or cloud storage) ──
models/
*.h5
*.pth
*.pt
*.onnx
*.tflite
*.pb

# ── Datasets ──
PlantVillage/
PlantVillage.zip

# ── Jupyter Notebooks ──
*.ipynb
.ipynb_checkpoints/

# ── Test Images in Root ──
*.jpg
*.jpeg
*.png
!frontend/src/**/*.jpg
!frontend/src/**/*.png
!frontend/public/**/*.png
!frontend/public/**/*.ico

# ── Node / Frontend ──
node_modules/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Docker ──
*.log
